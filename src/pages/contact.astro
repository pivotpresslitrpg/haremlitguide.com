---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Contact HaremLit Guide.">
  <div class="max-w-xl mx-auto px-4 py-12">
    <p class="text-sm font-semibold text-[#ec4899] uppercase tracking-wider mb-3">Contact</p>
    <h1 class="text-3xl font-bold text-white mb-4">Get in Touch</h1>
    <p class="text-[#888] mb-6">
      Recommendations, corrections, or general inquiries:
      <a href="mailto:hello@haremlitguide.com" class="text-[#ec4899] hover:underline">hello@haremlitguide.com</a>
    </p>
    <p class="text-[#888] text-sm">
      For questions about Harem-Lit.com, please use the contact form on that site directly.
    </p>
  </div>
</BaseLayout>

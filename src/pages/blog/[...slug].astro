---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateStr = new Date(post.data.date + 'T12:00:00').toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const pubDateISO = new Date(post.data.date + 'T12:00:00').toISOString();
const isBookReport = post.data.type === 'book_report';

const articleSchema = {
  "@context": "https://schema.org",
  "@type": isBookReport ? "Review" : "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": pubDateISO,
  "dateModified": pubDateISO,
  "author": {
    "@type": "Person",
    "name": "The HaremLit Guide",
    "url": "https://haremlitguide.com/about",
    "worksFor": { "@type": "Organization", "name": "Pivot Press Publishing" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "HaremLit Guide",
    "url": "https://haremlitguide.com"
  },
  "isPartOf": { "@type": "WebSite", "name": "HaremLit Guide", "url": "https://haremlitguide.com" },
  ...(isBookReport ? {
    "itemReviewed": {
      "@type": "Book",
      "name": post.data.title.replace(/^(Review:\s*|Book Report:\s*)/i, '')
    }
  } : {})
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://haremlitguide.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://haremlitguide.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title }
  ]
};

const faqSchema = post.data.faq?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.data.faq.map(({ q, a }: { q: string; a: string }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
} : null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedDate={post.data.date}
  schema={[articleSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <article class="max-w-3xl mx-auto px-4 py-10">
    <div class="mb-6">
      {post.data.type && (
        <span class="text-xs font-semibold text-[var(--color-brand)] uppercase tracking-wider">
          {post.data.type.replace(/_/g, ' ')}
        </span>
      )}
      <h1 class="text-3xl sm:text-4xl font-bold text-white mt-2 leading-tight">{post.data.title}</h1>
      <p class="text-[#888] mt-2 text-sm">{dateStr}</p>
    </div>
    <div class="prose">
      <Content />
    </div>

    <!-- Platform CTA -->
    <div class="mt-12 p-6 bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg text-center">
      <p class="text-white font-semibold mb-2">Discover more harem fantasy reads</p>
      <p class="text-[#888] text-sm mb-4">Browse ranked lists, track new releases, and find your next favorite series.</p>
      <a href="https://harem-lit.com" target="_blank" rel="noopener" class="inline-block bg-[var(--color-brand)] hover:opacity-90 text-white px-6 py-2.5 rounded font-medium transition-opacity">
        Explore Harem-Lit.com &rarr;
      </a>
    </div>
  </article>
</BaseLayout>

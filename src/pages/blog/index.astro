---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout
  title="HaremLit Blog — Guides, Lists & New Releases"
  description="Editorial posts from HaremLit Guide — author spotlights, genre guides, new release roundups, and harem fantasy coverage."
>
  <div class="max-w-4xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-bold text-white mb-8">All Posts</h1>
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map(post => {
          const dateStr = new Date(post.data.date + 'T12:00:00').toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric'
          });
          return (
            <article class="group border border-[#2e2e2e] rounded-lg bg-[#1a1a1a] hover:border-[var(--color-brand)]/40 transition-colors overflow-hidden">
              <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="block p-5">
                {post.data.type && (
                  <span class="text-xs font-semibold text-[var(--color-brand)] uppercase tracking-wider">
                    {post.data.type.replace(/_/g, ' ')}
                  </span>
                )}
                <h2 class="mt-1.5 font-bold text-white text-lg leading-snug group-hover:text-[var(--color-brand)] transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-[#888] line-clamp-2">{post.data.description}</p>
                <p class="mt-3 text-xs text-[#555]">{dateStr}</p>
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <p class="text-[#666]">No posts yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookCard from '../components/BookCard.astro';
import { getBooks, getRecentBooks } from '../lib/api';
import { listConfig } from '../lib/lists';

const [topBooks, recentBooks] = await Promise.all([
  getBooks({ sort: 'top_rated', limit: 5 }),
  getRecentBooks(30, 6),
]);

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "HaremLit Guide",
  "url": "https://haremlitguide.com",
  "description": "Reader guides and ranked lists for harem fantasy, cultivation novels, and men's romance fiction.",
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "HaremLit Guide",
  "url": "https://haremlitguide.com",
  "description": "Reader guides and ranked lists for harem fantasy and men's romance fiction.",
  "isPartOf": { "@type": "WebSite", "name": "Harem-Lit.com", "url": "https://harem-lit.com" },
  "knowsAbout": ["Harem Fantasy", "Men's Romance", "Isekai Romance", "Cultivation Harem", "LitRPG Harem"]
};
---

<BaseLayout
  title="HaremLit Guide — Harem Fantasy & Men's Romance Reading Guide"
  description="The reader's guide to harem fantasy, cultivation novels, and men's romance fiction. Ranked lists, genre breakdowns, and new release tracking."
  schema={[websiteSchema, orgSchema]}
>
  <!-- Hero -->
  <section class="border-b border-[#2e2e2e] py-12 px-4">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-semibold text-[#ec4899] uppercase tracking-wider mb-3">Harem Fantasy & Men's Romance</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight max-w-2xl">
        Find your next great harem fantasy read.
      </h1>
      <p class="mt-4 text-lg text-[#888] max-w-xl">
        Ranked lists, genre guides, and new release tracking for harem fantasy, cultivation, and men's adventure romance.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="/lists/" class="bg-[#ec4899] hover:bg-[#db2777] text-white px-5 py-2.5 rounded font-medium transition-colors">
          Browse Lists
        </a>
        <a href="/new-releases/" class="border border-[#2e2e2e] hover:border-[#ec4899]/50 text-[#888] hover:text-white px-5 py-2.5 rounded font-medium transition-colors">
          New Releases
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 py-10 grid grid-cols-1 lg:grid-cols-3 gap-10">

    <!-- Main column -->
    <div class="lg:col-span-2 space-y-12">

      <!-- New releases -->
      {recentBooks.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-xl font-bold text-white">New Releases</h2>
            <a href="/new-releases/" class="text-sm text-[#ec4899] hover:underline">See all →</a>
          </div>
          <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg px-4">
            {recentBooks.map(book => (
              <BookCard book={book} showDescription={false} />
            ))}
          </div>
        </section>
      )}

      <!-- Browse lists -->
      <section>
        <h2 class="text-xl font-bold text-white mb-5">Browse by Genre</h2>
        <div class="grid grid-cols-2 gap-3">
          {Object.entries(listConfig).map(([slug, config]) => (
            <a
              href={`/lists/${slug}/`}
              class="bg-[#1a1a1a] border border-[#2e2e2e] hover:border-[#ec4899]/40 rounded-lg p-4 text-sm font-medium text-[#888] hover:text-white transition-colors"
            >
              {config.title.replace(/^(The |Best )/, '')} →
            </a>
          ))}
        </div>
      </section>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-8">
      <section class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-white">Top Rated</h2>
          <a href="/lists/best-harem-fantasy-books/" class="text-xs text-[#ec4899] hover:underline">Full list →</a>
        </div>
        {topBooks.length > 0 ? (
          <div class="divide-y divide-[#2e2e2e]">
            {topBooks.map((book, i) => (
              <BookCard book={book} rank={i + 1} />
            ))}
          </div>
        ) : (
          <p class="text-sm text-[#666] py-4 text-center">Loading…</p>
        )}
      </section>

      <section class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <h2 class="font-bold text-white mb-3">Popular Lists</h2>
        <ul class="space-y-2 text-sm">
          <li><a href="/lists/best-harem-fantasy-books/" class="text-[#888] hover:text-[#ec4899] transition-colors">The 50 Best Harem Fantasy Books</a></li>
          <li><a href="/lists/best-cultivation-novels/" class="text-[#888] hover:text-[#ec4899] transition-colors">Best Cultivation Novels</a></li>
          <li><a href="/lists/best-harem-litrpg/" class="text-[#888] hover:text-[#ec4899] transition-colors">Best Harem LitRPG</a></li>
          <li><a href="/lists/best-completed-harem-series/" class="text-[#888] hover:text-[#ec4899] transition-colors">Best Completed Series</a></li>
        </ul>
      </section>
    </aside>
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy" description="HaremLit Guide privacy policy.">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-white mb-8">Privacy Policy</h1>
    <div class="space-y-4 text-[#aaa] leading-relaxed">
      <p>HaremLit Guide is a static editorial website. We do not collect personal data, require accounts, or use tracking cookies.</p>
      <h2 class="text-xl font-bold text-white mt-6">Analytics</h2>
      <p>We use <a href="https://plausible.io" target="_blank" rel="noopener" class="text-[#ec4899] hover:underline">Plausible Analytics</a>, a privacy-respecting platform that does not use cookies and collects no personally identifiable information.</p>
      <h2 class="text-xl font-bold text-white mt-6">Affiliate Links</h2>
      <p>This site contains Amazon affiliate links. Clicking these may result in a cookie being set by Amazon. Please refer to Amazon's privacy policy for details.</p>
      <h2 class="text-xl font-bold text-white mt-6">Contact</h2>
      <p>Questions? Email <a href="mailto:hello@haremlitguide.com" class="text-[#ec4899] hover:underline">hello@haremlitguide.com</a>.</p>
    </div>
  </div>
</BaseLayout>

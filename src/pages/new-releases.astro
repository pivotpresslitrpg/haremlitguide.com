---
import BaseLayout from '../layouts/BaseLayout.astro';

const thisMonth = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<BaseLayout
  title={`New Harem Fantasy Releases — ${thisMonth}`}
  description="The latest harem fantasy, cultivation, and reverse harem releases. Browse the full catalog on Harem-Lit.com."
>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <p class="text-sm font-semibold text-[#ec4899] uppercase tracking-wider mb-2">New Releases</p>
    <h1 class="text-3xl font-bold text-white mb-3">Latest Harem Fantasy Releases</h1>
    <p class="text-[#888] mb-10 leading-relaxed">
      New releases are tracked live on <strong class="text-white">Harem-Lit.com</strong> — the full database of harem fantasy,
      cultivation, reverse harem, and men's romance LitRPG, updated continuously.
    </p>

    <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-xl p-8 text-center">
      <p class="text-white text-lg font-semibold mb-2">Browse the Full New Releases Calendar</p>
      <p class="text-[#888] text-sm mb-6">
        Filter by subgenre, release date, or series. Hundreds of titles tracked across Amazon, Audible, and Royal Road.
      </p>
      <a
        href="https://harem-lit.com/new-releases"
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-3 bg-[#ec4899] hover:bg-[#db2777] text-white font-semibold rounded-lg transition-colors"
      >
        View New Releases on Harem-Lit.com &rarr;
      </a>
    </div>

    <div class="mt-10 grid sm:grid-cols-3 gap-4 text-center">
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <p class="text-white font-semibold mb-1">Harem Fantasy</p>
        <p class="text-[#888] text-sm">Power progression with a compelling ensemble cast</p>
      </div>
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <p class="text-white font-semibold mb-1">Cultivation</p>
        <p class="text-[#888] text-sm">Xianxia and wuxia traditions in English</p>
      </div>
      <div class="bg-[#1a1a1a] border border-[#2e2e2e] rounded-lg p-5">
        <p class="text-white font-semibold mb-1">Reverse Harem</p>
        <p class="text-[#888] text-sm">Female protagonist, multiple love interests</p>
      </div>
    </div>
  </div>
</BaseLayout>
